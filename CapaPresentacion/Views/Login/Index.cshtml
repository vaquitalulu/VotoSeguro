@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Voto Seguro — Login</title>
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                min-height: 100vh;
                background: linear-gradient(135deg, #0f2352 0%, #1a3a6b 55%, #2563eb 100%);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .card {
                background: #ffffff;
                border-radius: 18px;
                box-shadow: 0 24px 64px rgba(0,0,0,0.25);
                width: 100%;
                max-width: 420px;
                overflow: hidden;
            }

            .card-header {
                background: linear-gradient(135deg, #1a3a6b, #2563eb);
                padding: 32px 32px 24px;
                text-align: center;
            }

            .escudo {
                width: 64px;
                height: 64px;
                background: rgba(255,255,255,0.15);
                border: 2px solid rgba(255,255,255,0.3);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 14px;
                font-size: 28px;
            }

            .card-header h1 {
                color: #ffffff;
                font-size: 1.5rem;
                font-weight: 800;
                letter-spacing: -0.5px;
            }

            .card-header p {
                color: rgba(255,255,255,0.75);
                font-size: 0.85rem;
                margin-top: 4px;
            }

            /* Colegio seleccionado */
            .colegio-badge {
                background: rgba(255,255,255,0.15);
                border: 1px solid rgba(255,255,255,0.3);
                border-radius: 20px;
                padding: 5px 14px;
                font-size: 0.8rem;
                color: #ffffff;
                margin-top: 10px;
                display: inline-block;
            }

            .barra-dorada {
                height: 4px;
                background: linear-gradient(90deg, #f59e0b, #fbbf24, #f59e0b);
            }

            .card-body {
                padding: 28px 32px 32px;
            }

            .form-titulo {
                font-size: 0.82rem;
                font-weight: 600;
                color: #64748b;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 20px;
            }

            label {
                display: block;
                font-size: 0.78rem;
                font-weight: 600;
                color: #64748b;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 6px;
            }

            .campo {
                position: relative;
                margin-bottom: 20px;
            }

                .campo .icono {
                    position: absolute;
                    left: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    font-size: 16px;
                    color: #94a3b8;
                    pointer-events: none;
                }

                .campo input {
                    width: 100%;
                    height: 48px;
                    padding: 0 14px 0 42px;
                    border: 1.5px solid #e2e8f0;
                    border-radius: 10px;
                    font-size: 0.95rem;
                    font-family: inherit;
                    color: #1e293b;
                    background: #f8faff;
                    transition: border-color 0.2s, box-shadow 0.2s;
                    outline: none;
                }

                    .campo input:focus {
                        border-color: #2563eb;
                        box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
                        background: #ffffff;
                    }

            .btn-ingresar {
                width: 100%;
                height: 50px;
                background: linear-gradient(135deg, #2563eb, #1d4ed8);
                color: #ffffff;
                border: none;
                border-radius: 10px;
                font-size: 1rem;
                font-weight: 700;
                font-family: inherit;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                margin-top: 8px;
                box-shadow: 0 6px 20px rgba(37,99,235,0.35);
                transition: transform 0.15s, box-shadow 0.2s;
            }

                .btn-ingresar:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 28px rgba(37,99,235,0.45);
                }

                .btn-ingresar:active {
                    transform: translateY(0);
                }

            .mensaje {
                margin-top: 16px;
                padding: 12px 16px;
                border-radius: 8px;
                background: #fef2f2;
                border: 1px solid #fca5a5;
                color: #b91c1c;
                font-size: 0.88rem;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .btn-volver {
                display: block;
                text-align: center;
                margin-top: 14px;
                font-size: 0.82rem;
                color: #64748b;
                text-decoration: none;
            }

                .btn-volver:hover {
                    color: #2563eb;
                }

            .card-footer {
                background: #f8faff;
                border-top: 1px solid #e2e8f0;
                padding: 12px 32px;
                text-align: center;
                font-size: 0.78rem;
                color: #94a3b8;
            }
    </style>
</head>
<body>

    <div class="card">

        <div class="card-header">
            <div class="escudo">🛡️</div>
            <h1>Voto Seguro</h1>
            <p>Sistema de Votación Estudiantil</p>
            @if (TempData["NombreColegio"] != null)
            {
                <span class="colegio-badge">🏫 @TempData["NombreColegio"]</span>
            }
        </div>

        <div class="barra-dorada"></div>

        <div class="card-body">

            <p class="form-titulo">👤 Acceso de Estudiante</p>

            <form method="post">
                <input type="hidden" name="idColegio" value="@TempData["IdColegio"]" />

                <label>DNI:</label>
                <div class="campo">
                    <input type="text"
                           name="dni"
                           placeholder="Ej. 12345678"
                           maxlength="8"
                           autocomplete="username" />
                    <span class="icono">🪪</span>
                </div>

                <label>Clave:</label>
                <div class="campo">
                    <input type="password"
                           name="clave"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                    <span class="icono">🔒</span>
                </div>

                <button type="submit" class="btn-ingresar">
                    ➜ Ingresar al Sistema
                </button>

            </form>

            @if (!string.IsNullOrWhiteSpace(ViewBag.Mensaje as string))
            {
                <div class="mensaje">
                    ⚠️ @ViewBag.Mensaje
                </div>
            }

            <a asp-controller="Colegio" asp-action="Index" class="btn-volver">
                ← Cambiar colegio
            </a>

        </div>

        <div class="card-footer">
            🔐 Acceso exclusivo para estudiantes registrados
        </div>

    </div>

</body>
</html>